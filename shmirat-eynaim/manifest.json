{
  "manifest_version": 2,
  "name": "Shmirat Eynaim",
  "version": "1.0.0",
  "description": "Detects and hides images containing women using client-side ML face detection and gender classification.",
  "browser_specific_settings": {
    "gecko": {
      "id": "shmirat-eynaim@example.com",
      "strict_min_version": "91.0"
    }
  },
  "permissions": [
    "<all_urls>",
    "storage",
    "tabs",
    "activeTab",
    "menus"
  ],
  "background": {
    "page": "background.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-early.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-idris.js"],
      "css": ["content.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Shmirat Eynaim"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';",
  "web_accessible_resources": [
    "models/*",
    "lib/*",
    "lib/wasm/*"
  ]
}

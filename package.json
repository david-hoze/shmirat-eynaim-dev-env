{
  "name": "shmirat-eynaim-dev-env",
  "version": "1.0.0",
  "description": "Development environment for Shmirat Eynaim Firefox extension",
  "scripts": {
    "test": "npx playwright test --project=firefox",
    "test:headed": "npx playwright test --project=firefox --headed",
    "test:visual": "npx playwright test --project=firefox --grep @visual",
    "test:debug": "PWDEBUG=1 npx playwright test --project=firefox",
    "test:specific": "npx playwright test --project=firefox",
    "setup": "bash scripts/setup.sh",
    "setup:models": "node scripts/download-models.js",
    "package": "bash scripts/package.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
